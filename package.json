{
  "name": "liuyao-decision-assistant",
  "version": "0.2.0",
  "private": true,
  "description": "六爻决策助手 — monorepo",
  "scripts": {
    "dev:web": "pnpm --filter @liuyao/web dev",
    "dev:mobile": "pnpm --filter @liuyao/mobile dev",
    "dev:mini": "cd frontend && npm run dev:weapp",
    "build:web": "pnpm --filter @liuyao/web build",
    "build:mobile": "pnpm --filter @liuyao/mobile build",
    "build:mini": "cd frontend && npm run build:weapp",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
